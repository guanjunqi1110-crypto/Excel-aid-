# This folder is often a full Windows "Downloads" directory. Only track the app and
# related files to avoid committing unrelated downloads.
/*
!.gitignore
!app.py
!requirements.txt
!openai_key_local.txt.example
!README.md
!push-to-github.ps1
!Excel_Readiness_AI_Coach_Content_Pack.xlsx
!Excel_Readiness_AI_Coach_Content_Pack_with_sources.xlsx
!.streamlit/

# Local API keys (do not commit)
.streamlit/secrets.toml
openai_key_local.txt

# Python
__pycache__/
*.py[cod]
.venv/
venv/
env/

# OS
.DS_Store
Thumbs.db
